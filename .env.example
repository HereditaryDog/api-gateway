# ж•°жҚ®еә“й…ҚзҪ?
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/apigateway
# жҲ–иҖ?SQLite (ејҖеҸ‘жөӢиҜ•з”Ё)
